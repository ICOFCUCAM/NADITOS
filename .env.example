# ─── Postgres ───────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=naditos
POSTGRES_USER=naditos
POSTGRES_PASSWORD=naditos
DATABASE_URL=postgres://naditos:naditos@localhost:5432/naditos?sslmode=disable

# ─── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_SECRET=dev-only-change-me-dev-only-change-me-dev-only-change-me
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# ─── Service ports ──────────────────────────────────────────────────────
AUTH_PORT=8001
REGISTRY_PORT=8002
LICENSE_PORT=8003
INSURANCE_PORT=8004
INSPECTION_PORT=8005
FINES_PORT=8006
AUDIT_PORT=8007
ANPR_PORT=8008
NOTIFICATIONS_PORT=8009

# ─── Object storage (evidence) ──────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET_EVIDENCE=naditos-evidence
S3_ACCESS_KEY=naditos
S3_SECRET_KEY=naditos1234

# ─── Front-end ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8080
NEXT_PUBLIC_DEFAULT_TENANT=demo

# ─── Country / regulation ───────────────────────────────────────────────
DEFAULT_COUNTRY=XX
DEFAULT_LOCALE=en

# ─── Telemetry ──────────────────────────────────────────────────────────
LOG_LEVEL=info
OTEL_ENABLED=false
