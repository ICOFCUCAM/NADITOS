# Public runtime configuration for the Vercel-deployed police PWA.
#
# These MUST be set in the Vercel project settings (Production +
# Preview + Development) and the project re-deployed for changes to
# take effect — Next.js inlines NEXT_PUBLIC_* values into the client
# bundle at build time.
#
# Without NEXT_PUBLIC_API_BASE the app falls back to "http://localhost"
# which the browser cannot reach when the page itself is hosted on
# *.vercel.app — that's the "Failed to fetch" error on the login form.

# Public URL of the gateway service. Must be HTTPS in production.
# Example: https://gateway.nadit.example.gov
NEXT_PUBLIC_API_BASE=

# Default tenant slug presented on the login form. The user can still
# override it in the input.
NEXT_PUBLIC_DEFAULT_TENANT=demo
